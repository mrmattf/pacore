# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pacore

# Vector Store Configuration
# Options: 'pgvector' (default, uses PostgreSQL) or 'pinecone' (requires API key)
VECTOR_STORE=pgvector

# Pinecone Vector Database (only needed if VECTOR_STORE=pinecone)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=pacore-conversations

# Server
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your-very-secure-secret-key-change-in-production

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Default LLM Provider (optional)
DEFAULT_PROVIDER=anthropic

# Webhook base URL — used to construct callback URLs registered with Shopify and other platforms
# In production: set to your publicly accessible domain (e.g. https://pacore.yourapp.com)
# In development: use ngrok or similar (e.g. https://abc123.ngrok.io)
WEBHOOK_BASE_URL=https://your-pacore-domain.com
